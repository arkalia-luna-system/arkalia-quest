  "animations": {
    "pulse": {
      "css": "animation: badgePulse 2s ease-in-out infinite alternate;",
      "keyframes": "@keyframes badgePulse { from { transform: scale(1); } to { transform: scale(1.1); } }"
    },
    "glow": {
      "css": "animation: badgeGlow 2s ease-in-out infinite alternate;",
      "keyframes": "@keyframes badgeGlow { from { box-shadow: 0 0 5px currentColor; } to { box-shadow: 0 0 20px currentColor; } }"
    },
    "rainbow": {
      "css": "animation: badgeRainbow 3s ease-in-out infinite;",
      "keyframes": "@keyframes badgeRainbow { 0% { filter: hue-rotate(0deg); } 100% { filter: hue-rotate(360deg); } }"
    },
    "shake": {
      "css": "animation: badgeShake 0.5s ease-in-out infinite;",
      "keyframes": "@keyframes badgeShake { 0%, 100% { transform: translateX(0); } 25% { transform: translateX(-2px); } 75% { transform: translateX(2px); } }"
    },
    "flash": {
      "css": "animation: badgeFlash 1s ease-in-out infinite;",
      "keyframes": "@keyframes badgeFlash { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }"
    },
    "fire": {
      "css": "animation: badgeFire 2s ease-in-out infinite;",
      "keyframes": "@keyframes badgeFire { 0%, 100% { filter: hue-rotate(0deg) brightness(1); } 50% { filter: hue-rotate(30deg) brightness(1.2); } }"
    },
    "crown": {
      "css": "animation: badgeCrown 3s ease-in-out infinite;",
      "keyframes": "@keyframes badgeCrown { 0%, 100% { transform: rotate(0deg); } 25% { transform: rotate(5deg); } 75% { transform: rotate(-5deg); } }"
    },
    "shield": {
      "css": "animation: badgeShield 2s ease-in-out infinite;",
      "keyframes": "@keyframes badgeShield { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.05); } }"
    },
    "star": {
      "css": "animation: badgeStar 2s ease-in-out infinite;",
      "keyframes": "@keyframes badgeStar { 0%, 100% { transform: rotate(0deg) scale(1); } 50% { transform: rotate(180deg) scale(1.1); } }"
    },
    "moon": {
      "css": "animation: badgeMoon 4s ease-in-out infinite;",
      "keyframes": "@keyframes badgeMoon { 0%, 100% { filter: brightness(1) hue-rotate(0deg); } 50% { filter: brightness(1.3) hue-rotate(180deg); } }"
    },
    "none": {
      "css": "",
      "keyframes": ""
    }
  },
  "couleurs_rarete": {
