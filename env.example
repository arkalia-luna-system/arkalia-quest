# Configuration LUNA Hors Connexion
# Copier ce fichier vers .env puis adapter les valeurs.

# Environnement applicatif
# Valeurs recommandees:
# - dev local: FLASK_ENV=development, APP_ENV=development
# - prod:      FLASK_ENV=production,  APP_ENV=production
FLASK_ENV=development
APP_ENV=development
FLASK_DEBUG=1

# Reseau
HOST=0.0.0.0
PORT=5001

# Securite
# OBLIGATOIRE en production (voir app.py)
SECRET_KEY=change-me-with-a-long-random-secret

# Rate limiting API story (POST)
STORY_RATE_LIMIT_WINDOW_SECONDS=60
STORY_RATE_LIMIT_MAX_POSTS=60
